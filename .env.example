# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_API_KEY: Required for the interactive map to function correctly.
# Obtain a key from the Google Cloud Console with Maps JavaScript API enabled.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# OPENROUTER_API_KEY: Required during build time for geographic coordinate extraction
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# GITHUB_PAT: Personal Access Token with repo (contents: write) access to CoolAI-Studio/coge-podcast.
# Configure this in the Secrets panel in AI Studio UI to enable direct 'npm run sync:github' deployment.
GITHUB_PAT="YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
